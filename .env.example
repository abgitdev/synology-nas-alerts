# ─────────────────────────────────────────────────────────────────────────
#  synology-nas-alerts — example configuration.
#  Copy to .env  ( cp .env.example .env )  and fill in your own values.
#  .env is NOT committed (see .gitignore). Keep it 600:  chmod 600 .env
#
#  The file is read by all three scripts. Put shared keys in the root .env;
#  you may override them in a per-component .env if needed.
# ─────────────────────────────────────────────────────────────────────────

# ── Telegram (required) ──────────────────────────────────────────────────
# Bot token from @BotFather and the recipient chat id.
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE
TELEGRAM_CHAT_ID=PASTE_YOUR_CHAT_ID_HERE

# Only "telegram" is supported. HTTP request timeout to Telegram (3..60 sec).
NOTIFY_CHANNELS=telegram
NOTIFY_TIMEOUT_SECONDS=20

# ── security-alert ───────────────────────────────────────────────────────
# Extra trusted sources (comma-separated): IPs or SMB machine names that must
# not raise an alert. LAN / Tailscale / CGNAT are already trusted by default.
ALERT_WHITELIST_IPS=

# ── ups-alert ────────────────────────────────────────────────────────────
# UPS name for upsc (default ups@localhost) and an explicit upsc path (optional).
UPS_NAME=ups@localhost
UPSC_BIN=
# How many minutes after a power loss DSM enters safe standby
# (should match Control Panel → Hardware & Power → UPS).
DSM_UPS_STANDBY_MINUTES=15
# At which minutes without power to send interim reminders (comma-separated).
UPS_OUTAGE_ALERT_MINUTES=5,10

# ── Debug (security-alert / ups-alert) ───────────────────────────────────
# VERBOSE=1 prints NO_ALERT to stdout when there is no alert.
VERBOSE=0

# ═════════════════════════════════════════════════════════════════════════
#  The variables below are set in the DSM task environment / run.sh,
#  NOT in .env. Listed here for reference.
#
#  PYTHON_BIN=/usr/bin/python3      path to python3
#  TZ=UTC                           timezone for timestamps (defaults to UTC)
#  NAS_HEALTH_MAX_SECONDS=600       run timeout for nas-health   (run.sh)
#  SECURITY_ALERT_MAX_SECONDS=180   run timeout for security-alert
#  UPS_ALERT_MAX_SECONDS=120        run timeout for ups-alert
#  NAS_ALERT_MAX_SECONDS=...        shared fallback timeout for all three
#  *_BASE_DIR=...                   override a script's working directory
# ═════════════════════════════════════════════════════════════════════════
